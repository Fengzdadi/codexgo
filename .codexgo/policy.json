{
  "defaultDecision": "ask",
  "rules": [
    {
      "name": "codexgo allow prefix Bash commands",
      "decision": "allow",
      "tools": [
        "Bash"
      ],
      "match": "prefix",
      "commands": [
        "npm install lodash",
        "git commit",
        "git add"
      ]
    },
    {
      "name": "codexgo allow exact Bash commands",
      "decision": "allow",
      "tools": [
        "Bash"
      ],
      "match": "exact",
      "commands": [
        "npm ci",
        "go mod tidy",
        "git fetch"
      ]
    }
  ]
}
